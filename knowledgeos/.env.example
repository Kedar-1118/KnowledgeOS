# ═══════════════════════════════════════════
# KnowledgeOS — Environment Variables
# ═══════════════════════════════════════════
# Copy this file to .env and fill in all values.
# NEVER commit the .env file to version control.

# ─── Application ───
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ─── Google OAuth 2.0 ───
# Create credentials at https://console.cloud.google.com/apis/credentials
# Enable: Google Drive API, Google People API
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# ─── JWT Authentication ───
JWT_SECRET=your-jwt-secret-min-32-chars-long
JWT_EXPIRES_IN=7d

# ─── PostgreSQL (Prisma) ───
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://knowledgeos:knowledgeos_dev@localhost:5432/knowledgeos?schema=public

# ─── Redis ───
REDIS_URL=redis://localhost:6379

# ─── Qdrant (Vector Database) ───
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ─── Neo4j (Knowledge Graph) ───
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=knowledgeos_dev

# ─── ML Service ───
ML_SERVICE_URL=http://localhost:8000

# ─── AWS (Production) ───
AWS_REGION=us-east-1
AWS_S3_BUCKET=knowledgeos-prod-models
AWS_S3_CACHE_BUCKET=knowledgeos-prod-cache
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Google Gemini (for Q&A RAG pipeline — Phase 2) ───
GEMINI_API_KEY=

# ─── Logging ───
LOG_LEVEL=debug
